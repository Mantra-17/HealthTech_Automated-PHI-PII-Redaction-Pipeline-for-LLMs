# ═══════════════════════════════════════════════════════════
# PHI Redaction Pipeline — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it contains secret keys!
# ═══════════════════════════════════════════════════════════

# ── Flask Config ──────────────────────────────────────────
# Environment: development or production
FLASK_ENV=development

# Set to false in production!
FLASK_DEBUG=false

# Port the Flask server listens on
FLASK_PORT=5001

# Host — 0.0.0.0 means accessible from any network interface
FLASK_HOST=0.0.0.0

# Secret key for Flask session security — change this!
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── AI Provider (choose ONE and uncomment) ────────────────

# Option A: Google Gemini (free tier available)
# GEMINI_API_KEY=your_gemini_api_key_here

# Option B: Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option C: OpenAI GPT
# OPENAI_API_KEY=your_openai_api_key_here

# ── Redis / Vault ─────────────────────────────────────────
# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# How long (seconds) to keep token mappings in Redis
# 1800 = 30 minutes. After this, session data is auto-deleted.
# This ensures PHI is never stored longer than necessary.
VAULT_TTL_SECONDS=1800

# ── Pipeline Config ───────────────────────────────────────
# Maximum text length accepted by /api/redact (characters)
MAX_TEXT_LENGTH=10000

# Rate limit: max requests per minute per IP address
RATE_LIMIT_PER_MIN=20

# spaCy model to load for NLP detection
# en_core_web_sm = smaller, faster (recommended)
# en_core_web_lg = larger, more accurate
NLP_MODEL=en_core_web_sm

# ── Logging ───────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Path to audit log file
AUDIT_LOG_PATH=logs/audit.log

# Max audit log size in bytes before rotation (default: 1MB)
AUDIT_LOG_MAX_BYTES=1048576
